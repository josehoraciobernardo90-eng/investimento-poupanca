{
  "rules": {
    ".read": true,
    ".write": true,
    "users": {
      "$uid": {
        "nome": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".validate": "newData.val() === 'Ativo' || newData.val() === 'Congelado'"
        },
        "saldo_base": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "lucro_acumulado": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    "dashboard": {
      "caixa": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      },
      "lucros": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      },
      "naRua": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      },
      "total": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      }
    },
    "loanRequests": {
      "$req_id": {
        "valor": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        }
      }
    },
    "depositRequests": {
      "$req_id": {
        "valor": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        }
      }
    },
    "audit": {
      "$log_id": {
        "valor": {
          ".validate": "!newData.hasChild('valor') || (newData.isNumber() && newData.val() >= 0)"
        }
      }
    }
  }
}