{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "root.child('admins').child(auth.uid).exists()",
        ".validate": "newData.hasChildren(['nome', 'status', 'saldo_base'])",
        "nome": { ".validate": "newData.isString()" },
        "status": { ".validate": "newData.val() === 'Ativo' || newData.val() === 'Congelado'" },
        "saldo_base": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "lucro_acumulado": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "$other": { ".validate": false }
      }
    },
    
    "dashboard": {
      ".read": "auth != null",
      ".write": "root.child('admins').child(auth.uid).exists()",
      ".validate": "newData.hasChildren(['caixa', 'lucros', 'naRua', 'total'])",
      "caixa": { ".validate": "newData.isNumber() && newData.val() >= 0" },
      "lucros": { ".validate": "newData.isNumber() && newData.val() >= 0" },
      "naRua": { ".validate": "newData.isNumber() && newData.val() >= 0" },
      "total": { ".validate": "newData.isNumber() && newData.val() >= 0" }
    },

    "loans": {
      ".read": "auth != null",
      "$loan_id": {
        ".write": "root.child('admins').child(auth.uid).exists()",
        ".validate": "newData.hasChildren(['user_id', 'valor_original', 'taxa_atual', 'status', 'total_devido'])",
        "user_id": { ".validate": "newData.isString()" },
        "valor_original": { ".validate": "newData.isNumber() && newData.val() > 0" },
        "taxa_atual": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "status": { ".validate": "newData.val() === 'Ativo' || newData.val() === 'Atrasado' || newData.val() === 'Liquidado'" },
        "total_devido": { ".validate": "newData.isNumber() && newData.val() >= 0" }
      }
    },

    "loanDetails": {
      ".read": "auth != null",
      "$loan_id": {
        ".write": "root.child('admins').child(auth.uid).exists()"
      }
    },

    "userDetails": {
      "$uid": {
         ".read": "$uid === auth.uid || root.child('admins').child(auth.uid).exists()",
         ".write": "root.child('admins').child(auth.uid).exists()",
         "emCaixa": { ".validate": "newData.isNumber() && newData.val() >= 0" },
         "patrimonioTotal": { ".validate": "newData.isNumber() && newData.val() >= 0" }
      }
    },

    "loanRequests": {
      ".read": "auth != null",
      "$req_id": {
        ".write": "(newData.child('user_id').val() === auth.uid && !data.exists()) || root.child('admins').child(auth.uid).exists()",
        ".validate": "newData.hasChildren(['user_id', 'valor', 'status'])",
        "valor": { ".validate": "newData.isNumber() && newData.val() > 0" },
        "status": { 
          ".validate": "(newData.val() === 'Pendente' && !data.exists() && newData.child('user_id').val() === auth.uid) || root.child('admins').child(auth.uid).exists()" 
        }
      }
    },

    "depositRequests": {
       ".read": "auth != null",
       "$req_id": {
        ".write": "(newData.child('user_id').val() === auth.uid && !data.exists()) || root.child('admins').child(auth.uid).exists()",
        ".validate": "newData.hasChildren(['user_id', 'valor', 'status'])",
        "valor": { ".validate": "newData.isNumber() && newData.val() > 0" },
        "status": { 
           ".validate": "(newData.val() === 'Pendente' && !data.exists()) || root.child('admins').child(auth.uid).exists()" 
        }
      }
    },

    "audit": {
      ".read": "root.child('admins').child(auth.uid).exists()", 
      "$log_id": {
        ".write": "root.child('admins').child(auth.uid).exists()",
        ".validate": "!data.exists() && newData.hasChildren(['tipo', 'desc', 'valor'])",
        "valor": { ".validate": "newData.isNumber() && newData.val() >= 0" }
      }
    },

    "admins": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
